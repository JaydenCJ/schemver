{
  "name": "schemver",
  "version": "0.1.0",
  "description": "Diffs two JSON Schemas and classifies every change as breaking, risky, or additive — a compatibility-aware semver verdict with per-path reasons.",
  "author": "JaydenCJ",
  "license": "MIT",
  "type": "module",
  "bin": {
    "schemver": "dist/cli.js"
  },
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "examples",
    "README.md",
    "LICENSE"
  ],
  "engines": {
    "node": ">=22.13"
  },
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "test": "npm run build && node --test \"tests/*.test.mjs\"",
    "smoke": "bash scripts/smoke.sh"
  },
  "keywords": [
    "json-schema",
    "semver",
    "breaking-changes",
    "schema-diff",
    "compatibility",
    "api-versioning",
    "ci",
    "cli"
  ],
  "devDependencies": {
    "typescript": "^5.7.0"
  },
  "repository": {
    "type": "git",
    "url": "git+https://github.com/JaydenCJ/schemver.git"
  },
  "homepage": "https://github.com/JaydenCJ/schemver#readme",
  "bugs": {
    "url": "https://github.com/JaydenCJ/schemver/issues"
  }
}
